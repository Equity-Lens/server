    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.16.3",
    "serverless-http": "^3.2.0",
    "socket.io": "^4.8.1",
    "ws": "^8.18.3"
