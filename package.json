{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "build:lambda": "npm run build && npm run bundle:lambda",
    "bundle:lambda": "webpack --mode production",
    "start": "node dist/index.js",
    "start:lambda": "node dist/lambda.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "package:lambda": "npm run build:lambda && cd dist && zip -r ../lambda-deployment.zip .",
    "deploy:lambda": "npm run package:lambda && aws lambda update-function-code --function-name pocketstock-api --zip-file fileb://lambda-deployment.zip"
  },
